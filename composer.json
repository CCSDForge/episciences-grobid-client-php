{
    "name": "episciences/grobid-client-php",
    "description": "PHP client library for the GROBID REST API",
    "type": "library",
    "license": "MIT",
    "keywords": ["grobid", "pdf", "tei", "xml", "scientific", "references"],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.9",
        "psr/log": "^3.0",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Episciences\\GrobidClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Episciences\\GrobidClient\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/grobid-client"
    ],
    "config": {
        "sort-packages": true
    }
}
